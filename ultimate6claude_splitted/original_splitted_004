function mkNode(id,d,p){
  const isS=id==='start',isT=!Object.keys(d.answers||{}).length,isSel=id===selId;
  const el=document.createElement('div');
  el.className='node'+(isS?' nstart':'')+(isT?' nterm':'')+(isSel?' selected':'');
  el.dataset.id=id;
  el.style.cssText=`left:${p.x}px;top:${p.y}px`;

  const title=d.title||'';
  // Answers shown as colored dot + text label, not pills
  const ansHtml=Object.entries(d.answers||{}).map(([a,tv],i)=>{
    const c=C[i%C.length];
    return `<div class="nans"><div class="ndot" style="background:${c}"></div><div class="nans-label" style="color:${c}" title="${ea(a)} → ${ea(tv)}">${eh(a)}</div></div>`;
  }).join('');

  const badge=(isS?'▶ START — ':'')+(isT?'● VÝSLEDEK — ':'')+id;
  el.innerHTML=`
    <div class="nhead">
      <div class="nbadge">${badge}</div>
      <div class="ntitle${!title?' empty':''}">${eh(title)||'(bez názvu)'}</div>
    </div>
    <div class="nbody">${ansHtml}<div class="nadd" data-addans="${id}">＋ odpověď</div></div>`;

  el.addEventListener('mousedown',e=>{
    if(e.button!==0)return;e.stopPropagation();
    if(e.target.closest('[data-addans]')){quickAdd(id);return;}
    selectNode(id);
    // FIX: read current position from pos[] directly, not from closure p
    const cur=pos[id]||{x:0,y:0};
    _drag={type:'node',id,sx:e.clientX,sy:e.clientY,nx:cur.x,ny:cur.y};
    CT.style.cursor='grabbing';
  });
  return el;
}

