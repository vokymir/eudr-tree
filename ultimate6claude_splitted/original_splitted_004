function diagName(){
  return (typeof tree._name==='string'&&tree._name.trim())||'';
}

function exportSlug(){
  const n=diagName();
  if(!n)return 'eudr-strom';
  return n.toLowerCase().replace(/[^a-z0-9\u00c0-\u024f]+/gi,'-').replace(/-+/g,'-').replace(/^-|-$/g,'');
}

