// HELPERS
// ══════════════════════════════════════════════
function nodeEntries(){return Object.entries(tree).filter(([k])=>!k.startsWith('_'));}
function nodeIds(){return Object.keys(tree).filter(k=>!k.startsWith('_'));}
function fields(){return tree._fields||[];}
function eh(s){return(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function ea(s){return(s||'').replace(/"/g,'&quot;').replace(/</g,'&lt;');}

// Hex → rgba string for btn color derivation
function hexRgba(hex,a){
  hex=hex.replace('#','');
  if(hex.length===3)hex=hex.split('').map(x=>x+x).join('');
  const r=parseInt(hex.slice(0,2),16),g=parseInt(hex.slice(2,4),16),b=parseInt(hex.slice(4,6),16);
  if(isNaN(r))return `rgba(40,120,50,${a})`;
  return `rgba(${r},${g},${b},${a})`;
}

// ══════════════════════════════════════════════
// LAYOUT
// ══════════════════════════════════════════════
function autoLayout(){
  const lvls={},seen=new Set(),ids=nodeIds();
  const root=ids.includes('start')?'start':ids[0];
  if(!root)return;
  const q=[{id:root,l:0}];seen.add(root);
  while(q.length){
    const{id,l}=q.shift();
    if(!lvls[l])lvls[l]=[];
    lvls[l].push(id);
    if(tree[id])for(const tv of Object.values(tree[id].answers||{}))
      if(!seen.has(tv)&&tree[tv]){seen.add(tv);q.push({id:tv,l:l+1});}
  }
  const CW=295,RH=200;pos={};
  for(const[l,nids]of Object.entries(lvls)){
    const sy=700-nids.length*RH/2;
    nids.forEach((id,i)=>pos[id]={x:80+ +l*CW,y:sy+i*RH});
  }
  let oy=60;
  for(const id of ids)if(!pos[id]){pos[id]={x:60,y:oy};oy+=180;}
}

function nodeH(id){
  const n=tree[id];if(!n)return NH+NBP*2+ADDH;
  return NH+NBP*2+Object.keys(n.answers||{}).length*ANH+ADDH;
}

