function renderNED(){
  const el=document.getElementById('ned');
  if(!selId||!tree[selId]){
    const hint=t('clickEdit').replace('\n','<br>');
    el.innerHTML=`<div class="neempty"><big>🌲</big>${hint}</div>`;
    return;
  }
  const id=selId,nd=tree[id];
  const ansl=Object.entries(nd.answers||{});
  const allIds=nodeIds();
  const flds=fields();

  const customFldHtml=flds.length?`
    <div class="nesec">${t('customFields')}<div class="nesec-line"></div></div>
    ${flds.map(f=>`
      <div class="neg">
        <div class="nelabel">${eh(f.label)} <span class="ltok">{${f.id}}</span></div>
        <input class="neinput" value="${ea(nd[f.id]||'')}" placeholder="${ea(f.label)}…"
          onchange="uf('${id}','${f.id}',this.value)">
      </div>`).join('')}`:'';

  el.innerHTML=`
    <div class="neg">
      <div class="nelabel">${t('nid')}</div>
      <input class="neinput" value="${ea(id)}" readonly>
    </div>
    <div class="neg">
      <div class="nelabel">${t('ntitle')} <span class="ltok">{title}</span></div>
      <input class="neinput" value="${ea(nd.title||'')}" placeholder="Otázka…"
        oninput="uf('${id}','title',this.value)">
    </div>
    <div class="neg">
      <div class="nelabel">${t('ndesc')} <span class="ltok">{description}</span></div>
      <textarea class="netarea" placeholder="Doplňující popis…"
        oninput="uf('${id}','description',this.value)">${eh(nd.description||'')}</textarea>
    </div>
    ${customFldHtml}
    <div class="nesec">${t('answers')}<div class="nesec-line"></div></div>
    <div id="ne-ans">
      ${ansl.map(([a,tv],i)=>{
        const c=C[i%C.length];
        const opts=allIds.map(nid=>`<option value="${nid}"${nid===tv?' selected':''}>${nid}</option>`).join('');
        return `<div class="acard">
          <div class="nelabel" style="color:${c};margin-bottom:5px">${t('answer')} ${i+1}</div>
          <div class="acard-top">
            <div class="adot" style="background:${c}"></div>
            <input class="neinput" style="flex:1" value="${ea(a)}" placeholder="Text odpovědi"
              onchange="chAns('${id}',${i},this.value,null)">
            <button class="adel" onclick="delAns('${id}',${i})">×</button>
          </div>
          <div class="nelabel" style="margin-top:5px">${t('leadsTo')}</div>
          <select class="neselect" onchange="chAns('${id}',${i},null,this.value)">${opts}</select>
        </div>`;
      }).join('')}
    </div>
    <button class="addansbtn" onclick="addAns('${id}')">${t('addAns')}</button>
    ${id!=='start'?`<button class="delnodebtn" onclick="delNode('${id}')">${t('delNode')} &quot;${id}&quot;</button>`:''}
  `;
}

// ══════════════════════════════════════════════
// TREE MUTATIONS
// ══════════════════════════════════════════════
function uf(id,f,v){
  if(!tree[id])return;
  tree[id][f]=v;
  refreshNode(id);renderJSONArea();renderPreview();
}

function chAns(nid,idx,newT,newTgt){
  if(!tree[nid])return;
  const e=Object.entries(tree[nid].answers||{});
  const[ot,og]=e[idx]||['',''];
  const tv=newT!==null?newT:ot,tg=newTgt!==null?newTgt:og;
  const f={};e.forEach(([k,v],i)=>{f[i===idx?tv:k]=i===idx?tg:v;});
  tree[nid].answers=f;
  refreshNode(nid);renderArrows();renderJSONArea();renderPreview();
}

function addAns(nid){
  if(!tree[nid])return;
  let tv='nová odpověď',n=2;
  while(tree[nid].answers[tv])tv=`nová odpověď ${n++}`;
  tree[nid].answers[tv]=nodeIds()[0]||nid;
  refreshNode(nid);renderArrows();renderNED();renderJSONArea();renderPreview();
}

function quickAdd(nid){addAns(nid);selectNode(nid);}

function delAns(nid,idx){
  if(!tree[nid])return;
  const e=Object.entries(tree[nid].answers||{}),f={};
  e.forEach(([k,v],i)=>{if(i!==idx)f[k]=v;});
  tree[nid].answers=f;
  refreshNode(nid);renderArrows();renderNED();renderJSONArea();renderPreview();
}

function delNode(id){
  if(id==='start'){notify(t('nCannotDel'));return;}
  delete tree[id];delete pos[id];
  for(const n of Object.values(tree))
    if(n&&n.answers)for(const[k,v]of Object.entries(n.answers))if(v===id)delete n.answers[k];
  if(selId===id)selId=null;
  renderCanvas();renderNED();renderJSONArea();renderPreview();
}

function refreshNode(id){
  const p=pos[id],old=CT.querySelector(`.node[data-id="${id}"]`);
  if(old&&p&&tree[id])CT.replaceChild(mkNode(id,tree[id],p),old);
}

